# Partie 1 : Analyse de séquences ADN (génome SARS-CoV-2)
def analyse_genome_sars_cov2():
    # Téléchargement des données publiques depuis NCBI GenBank
    # Utilisez votre email pour Entrez (remplacez par le vôtre)
    Entrez.email = "votre.email@example.com"
    
    # ID du génome SARS-CoV-2 (exemple : référence NC_045512)
    handle = Entrez.efetch(db="nucleotide", id="NC_045512", rettype="gb", retmode="text")
    record = SeqIO.read(handle, "genbank")
    handle.close()
    
    sequence = record.seq
    print(f"Séquence du génome SARS-CoV-2 téléchargée : {len(sequence)} bases")
    
    # Calcul de la composition en bases (GC%)
    gc_content = gc_fraction(sequence) * 100
    print(f"Contenu GC : {gc_content:.2f}%")
    
    # Chercher des motifs (ex. : site de restriction EcoRI : GAATTC)
    motif = "GAATTC"
    positions = [m.start() for m in re.finditer(motif, str(sequence))]
    print(f"Nombre de sites EcoRI trouvés : {len(positions)}")
    if positions:
        print(f"Positions des 5 premiers : {positions[:5]}")
    
    # Alignement de séquences simples (utilisation de Biopython pour Needleman-Wunsch)
    seq1 = sequence[:100]  # Première partie
    seq2 = sequence[100:200]  # Seconde partie (pour demo)
    aligner = PairwiseAligner()
    aligner.mode = 'global'  # Needleman-Wunsch
    alignments = aligner.align(seq1, seq2)
    print("Alignement exemple :")
    print(alignments[0])
    
    # Bonus : Comparaison de variants (ex. : original vs Delta - IDs simplifiés)
    # Pour un vrai variant, utilisez un autre ID, ex. MZ344997 pour Delta-like
    handle_delta = Entrez.efetch(db="nucleotide", id="MZ344997", rettype="gb", retmode="text")
    record_delta = SeqIO.read(handle_delta, "genbank")
    handle_delta.close()
    seq_delta = record_delta.seq[:len(sequence)]  # Troncature pour comparaison
    alignments_variant = aligner.align(sequence[:1000], seq_delta[:1000])  # Limité pour perf
    print(f"Score d'alignement avec variant : {alignments_variant[0].score}")
    
    # Visualisation d'un arbre phylogénétique simple
    # Pour demo, alignement multiple avec ClustalW (installez ClustalW séparément si besoin)
    # Écrivez des séquences dans un fichier FASTA
    with open("sequences.fasta", "w") as f:
        f.write(">SARS-CoV-2\n" + str(sequence[:500]) + "\n")
        f.write(">Variant\n" + str(seq_delta[:500]) + "\n")
    
    clustalw_cline = ClustalwCommandline("clustalw2", infile="sequences.fasta")
    stdout, stderr = clustalw_cline()
    
    # Lire l'arbre
    tree = Phylo.read("sequences.dnd", "newick")
    Phylo.draw_ascii(tree)
    
# Partie 2 : Modélisation biologique simple (modèle SIR pour épidémie)
def modelisation_sir():
    # Modèle SIR : Susceptible, Infected, Recovered
    def sir_model(y, t, beta, gamma):
        S, I, R = y
        dS_dt = -beta * S * I
        dI_dt = beta * S * I - gamma * I
        dR_dt = gamma * I
        return [dS_dt, dI_dt, dR_dt]
    
    # Paramètres initiaux
    N = 1000  # Population
    I0 = 1    # Infectés initiaux
    R0 = 0    # Récupérés initiaux
    S0 = N - I0 - R0
    beta = 0.3  # Taux d'infection
    gamma = 0.1 # Taux de récupération
    
    t = np.linspace(0, 100, 1000)  # Temps
    
    # Résolution ODE
    solution = odeint(sir_model, [S0, I0, R0], t, args=(beta, gamma))
    S, I, R = solution.T
    
    # Visualisation
    plt.figure()
    plt.plot(t, S, label='Susceptibles')
    plt.plot(t, I, label='Infectés')
    plt.plot(t, R, label='Récupérés')
    plt.xlabel('Temps')
    plt.ylabel('Population')
    plt.title('Modèle SIR')
    plt.legend()
    plt.show()
    
