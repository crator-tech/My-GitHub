# Partie 3 : Analyse de données biologiques
def analyse_donnees_bio():
    # Exemple : Télécharger un dataset FASTA d'UniProt (ex. insuline humaine)
    # Pour demo, supposons un fichier local 'insuline.fasta' téléchargé manuellement
    # Ou utilisez Entrez pour protéines
    Entrez.email = "votre.email@example.com"
    handle = Entrez.efetch(db="protein", id="P01308", rettype="fasta", retmode="text")  # Insuline humaine
    record = SeqIO.read(handle, "fasta")
    handle.close()
    
    # Stats basiques
    seq = record.seq
    base_counts = {'A': seq.count('A'), 'C': seq.count('C'), 'G': seq.count('G'), 'T': seq.count('T')}
    print("Comptage des bases (pour ADN, adaptez pour protéines) :", base_counts)
    
    # Visualisation simple (histogramme)
    plt.bar(base_counts.keys(), base_counts.values())
    plt.title('Composition en bases')
    plt.show()
    
    # Prédiction structure secondaire ARN simple (règles basiques : appariement GC/AU)
    # Pour demo, sur une petite séquence ARN
    arn_seq = "GGAUCGAUCGUAUCG"
    # Implémentation basique : compter paires possibles (non optimal)
    pairs = arn_seq.count("GC") + arn_seq.count("CG") + arn_seq.count("AU") + arn_seq.count("UA")
    print(f"Nombre de paires potentielles dans {arn_seq} : {pairs}")

# Partie 4 : Introduction au Machine Learning
def intro_ml():
    # Dataset simple : Iris pour demo (adapté à bio : classification fleurs comme "protéines")
    from sklearn.datasets import load_iris
    data = load_iris()
    X = data.data
    y = data.target
    
    X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2)
    
    clf = RandomForestClassifier()
    clf.fit(X_train, y_train)
    predictions = clf.predict(X_test)
    print(f"Précision : {accuracy_score(y_test, predictions)}")
    
